<BorderPane prefHeight="400.0" prefWidth="790.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <Pane fx:id="container" minHeight="360.0" minWidth="360.0" prefHeight="360.0" prefWidth="360.0" style="-fx-background-color:#222;" BorderPane.alignment="CENTER">
            <Canvas fx:id="canvas" />
        </Pane>
    </center>
    <top>
        <ToolBar prefHeight="40.0" prefWidth="854.0" BorderPane.alignment="CENTER">
            <items>
                <ChoiceBox fx:id="chbMode" prefWidth="80.0">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Pen" />
                            <String fx:value="Eraser" />
                            <String fx:value="Bucket" />
                        </FXCollections>
                    </items>
                </ChoiceBox>
                <ChoiceBox fx:id="chbSize" prefWidth="70.0">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Thin"/>
                            <String fx:value="Medium"/>
                            <String fx:value="Thick"/>
                        </FXCollections>
                    </items>
                </ChoiceBox>
                <Pane fx:id="paneColor" prefHeight="30.0" prefWidth="30.0" />
                <Pane fx:id="panePicker" prefHeight="30.0" prefWidth="30.0" />
            </items>
        </ToolBar>
    </top>
    <right>
        <VBox minWidth="250.0" prefWidth="200.0">
            <TextArea fx:id="areaMsg" wrapText="true" VBox.vgrow="ALWAYS" editable="False"/>
            <HBox>
                <TextField fx:id="txtMsg" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEmoji" text="😊" />
                <Button fx:id="btnSend" text="Send" />
            </HBox>
        </VBox>
    </right>
   <left>
       <VBox alignment="TOP_CENTER" minWidth="105.0" prefHeight="360.0" prefWidth="105.0" BorderPane.alignment="CENTER">
           <children>
               <Button fx:id="btnSave" alignment="CENTER" maxWidth="1.7976931348623157E308"
                       mnemonicParsing="false" text="Save" textAlignment="CENTER" VBox.vgrow="ALWAYS">
                   <VBox.margin>
                       <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                   </VBox.margin>
               </Button>
               <Button fx:id="btnLoad" alignment="CENTER" maxWidth="1.7976931348623157E308"
                       mnemonicParsing="false" text="Load" textAlignment="CENTER" VBox.vgrow="ALWAYS">
                   <VBox.margin>
                       <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                   </VBox.margin>
               </Button>
               <Button fx:id="btnReset" alignment="CENTER" maxWidth="1.7976931348623157E308"
                       mnemonicParsing="false" text="Reset" textAlignment="CENTER" VBox.vgrow="ALWAYS">
                   <VBox.margin>
                       <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                   </VBox.margin>
               </Button>
           </children>
       </VBox>
   </left>
</BorderPane>
